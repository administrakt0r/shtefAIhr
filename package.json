{
  "name": "umjetnainteligencijablog",
  "version": "1.1.0",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "generate:post-images": "node scripts/generate-post-images.mjs",
    "dev": "next dev",
    "generate:rss": "node scripts/generate-rss.mjs",
    "generate:derived": "pnpm generate:post-images && pnpm generate:rss",
    "predev": "pnpm generate:derived",
    "prebuild": "pnpm generate:derived",
    "build": "next build",
    "start": "next start",
    "validate:bot-pr": "node scripts/validate-bot-pr.mjs",
    "lint": "eslint src scripts next.config.ts postcss.config.mjs",
    "lint:fix": "eslint src scripts next.config.ts postcss.config.mjs --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
    "check-types": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@mdx-js/loader": "3.1.1",
    "@mdx-js/react": "3.1.1",
    "@next/mdx": "16.1.6",
    "@playwright/test": "^1.58.2",
    "@types/mdx": "2.0.13",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.562.0",
    "marked": "^17.0.3",
    "next": "16.1.1",
    "next-themes": "0.4.6",
    "playwright": "^1.58.2",
    "radix-ui": "1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sharp": "^0.34.5",
    "tailwind-merge": "3.4.0",
    "wrangler": "^4.77.0"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "5.6.1",
    "@tailwindcss/postcss": "4.1.18",
    "@types/node": "22.19.3",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.2",
    "eslint-config-next": "16.1.1",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.7.4",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwindcss": "4.1.18",
    "tsx": "^4.21.0",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3"
  }
}
